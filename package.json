{
  "name": "swift_tabs",
  "version": "1.0.0",
  "description": "A Chrome extension for tab management with gesture controls",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "build:demo": "rollup -c && rm -rf dist/demo/dist && cp src/demo/demo-shell.html dist/demo/demo.html",
    "dev": "rollup -c -w",
    "start": "npm run dev"
  },
  "keywords": [
    "chrome-extension",
    "svelte",
    "tab-management"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-css-only": "^4.0.0",
    "rollup-plugin-svelte": "^7.0.0",
    "svelte": "^4.0.0"
  },
  "dependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-image": "^3.0.0"
  }
}