{
    "manifest_version": 3,
    "name": "Swift Tabs",
    "version": "1.0",
    "description": "Tab management with gesture controls",
    "permissions": [
        "tabs",
        "storage",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "dist/content.css"
            ],
            "js": [
                "dist/content.js"
            ]
        }
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}